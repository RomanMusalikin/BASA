<?xml version="1.0" encoding="utf-8" ?>
<Autodiscover xmlns="http://schemas.microsoft.com/exchange/autodiscover/responseschema/2006">
  <Response xmlns="http://schemas.microsoft.com/exchange/autodiscover/outlook/responseschema/2006a">
    <Account>
      <AccountType>email</AccountType>
      <Action>redirectUrl</Action>
      <RedirectUrl>https://mail.2bits1.local/autodiscover/autodiscover.xml</RedirectUrl>
    </Account>
  </Response>
</Autodiscover>


New-ExchangeCertificate `
    -FriendlyName "Exchange2016" `
    -SubjectName "CN=mail.2bits1.local" `
    -DomainName "mail.2bits1.local","autodiscover.2bits1.local","MAIL" `
    -PrivateKeyExportable $true `
    -Services "IIS,SMTP"

Enable-ExchangeCertificate -Thumbprint "ВСТАВЬ_THUMBPRINT" -Services "IIS,SMTP" -Force

Set-Service MSExchangeIMAP4 -StartupType Automatic
Start-Service MSExchangeIMAP4
Set-Service MSExchangeIMAP4BE -StartupType Automatic
Start-Service MSExchangeIMAP4BE


Add-PSSnapin Microsoft.Exchange.Management.PowerShell.SnapIn
Set-ImapSettings -LoginType PlainTextLogin
Restart-Service MSExchangeIMAP4
Restart-Service MSExchangeIMAP4BE

Add-PSSnapin Microsoft.Exchange.Management.PowerShell.SnapIn
Get-ImapSettings | Select LoginType, AuthenticationMethods


Set-ImapSettings -AuthenticationMethods PlainTextLogin
Restart-Service MSExchangeIMAP4
Restart-Service MSExchangeIMAP4BE


Set-ImapSettings -LoginType PlainTextLogin -UnencryptedOrTLSBindings 0.0.0.0:143
Restart-Service MSExchangeIMAP4
Restart-Service MSExchangeIMAP4BE
